# Estimador de Yang-Zhang (Open/High/Low/Close)
# Trata explicitamente gaps overnight (Close[t-1] → Open[t]) e movimentos de abertura
# Combina 3 componentes: variância overnight, variância open-to-close e Rogers-Satchell
# k ótimo minimiza o erro de estimação: k = 0.34 / (1.34 + (n+1)/(n-1))
# .clip(lower=0) descarta variâncias negativas espúrias por arredondamento

df["retorno"] = df["Close"].pct_change()
df = df.dropna()

def hv_yang_zhang(janela):
    n = janela

    # gap overnight: retorno do Close[t-1] para Open[t]
    log_open  = np.log(df["Open"] / df["Close"].shift(1))
    # retorno open-to-close
    log_close = np.log(df["Close"] / df["Open"])

    # Rogers-Satchell: componente intraday puro (sem overnight)
    rs = (
        np.log(df["High"] / df["Close"]) * np.log(df["High"] / df["Open"])
        + np.log(df["Low"]  / df["Close"]) * np.log(df["Low"]  / df["Open"])
    )

    k = 0.34 / (1.34 + (n + 1) / (n - 1))

    var_open  = log_open.rolling(n).var()
    var_close = log_close.rolling(n).var()
    var_rs    = rs.rolling(n).mean()

    yz = (var_open + k * var_close + (1 - k) * var_rs).clip(lower=0)
    return yz ** 0.5 * (DIAS_ANO ** 0.5)

