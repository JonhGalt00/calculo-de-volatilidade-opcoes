def get_selic():
    try:
        import requests
        url = "https://api.bcb.gov.br/dados/serie/bcdata.sgs.11/dados/ultimos/1?formato=json"
        resp = requests.get(url, timeout=5)
        selic_diaria = float(resp.json()[0]["valor"].replace(",", "."))
        return (1 + selic_diaria / 100) ** 252 - 1
    except Exception:
        print("⚠️  Não foi possível buscar a Selic — usando valor fixo de fallback (14.65%)")
        return 0.1465

