            return "║ forte venda de vol║"
        elif score < 0.8:
            return "║forte compra de vol║"
        else:
            return "║             neutro║"

    CADEIA["sinal"] = CADEIA["score"].apply(sinal_score)

    def regime_iv(iv):
        if iv > hv_curta and iv > hv_longa:
            return "IV > HV curta e longa → vol elevada nos dois horizontes"
        elif iv > hv_curta and iv <= hv_longa:
            return "IV > HV curta mas ≤ HV longa → vol elevada no curto prazo"
        elif iv <= hv_curta and iv > hv_longa:
            return "IV ≤ HV curta mas > HV longa → vol comprimida no curto prazo"
        else:
            return "IV < HV curta e longa → vol abaixo dos dois horizontes"
        
    CADEIA["regime_hv"] = np.select(
    [
        (CADEIA["iv"] > hv_curta) & (CADEIA["iv"] > hv_longa),
        (CADEIA["iv"] > hv_curta) & (CADEIA["iv"] <= hv_longa),
        (CADEIA["iv"] <= hv_curta) & (CADEIA["iv"] > hv_longa),
    ],
    [
        "IV > HV curta e longa",
        "IV > HV curta",
        "IV > HV longa",
    ],
    default="IV < HV"
)

    CADEIA        = CADEIA.dropna(subset=["iv", "hv"])
    cadeia_sorted = CADEIA.sort_values("strike")

    puts  = cadeia_sorted[cadeia_sorted["tipo"] == "put"]
    calls = cadeia_sorted[cadeia_sorted["tipo"] == "call"]

    def calcular_skew(grupo):
        if len(grupo) < 2:
            return None, None, None
        x          = grupo["moneyness"].values
        y          = grupo["iv"].values
        coef       = np.polyfit(x, y, 1)
        skew_slope = coef[0]

        eh_smile = False
        if len(grupo) >= 5:
            meio        = grupo["iv"].iloc[len(grupo) // 2]
            iv_extremos = (grupo["iv"].iloc[0] + grupo["iv"].iloc[-1]) / 2
            eh_smile    = meio < iv_extremos * 0.95

        if eh_smile:
            tipo_skew = "smile (ATM mais barato que as pontas)"
        elif abs(skew_slope) < 0.02:
            tipo_skew = "flat"
        elif skew_slope < -0.05:
            tipo_skew = "negativo (put skew)"
        elif skew_slope > 0.05:
            tipo_skew = "positivo (call skew)"
        else:
            tipo_skew = "leve"

        return skew_slope, tipo_skew, eh_smile

    skew_slope_puts,  tipo_skew_puts,  _ = calcular_skew(puts)
    skew_slope_calls, tipo_skew_calls, _ = calcular_skew(calls)

    print(f"\n--- Cadeia de opções — IV e classificação ---\n")
