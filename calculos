def black_scholes(S, K, T, r, sigma, tipo, q=0):
    d1 = (np.log(S / K) + (r - q + 0.5 * sigma ** 2) * T) / (sigma * np.sqrt(T))
    d2 = d1 - sigma * np.sqrt(T)
    if tipo == "call":
        return S * np.exp(-q * T) * norm.cdf(d1) - K * np.exp(-r * T) * norm.cdf(d2)
    else:
        return K * np.exp(-r * T) * norm.cdf(-d2) - S * np.exp(-q * T) * norm.cdf(-d1)

def calcular_iv(S, K, T, r, preco_opcao, tipo, q=0):
    objetivo = lambda sigma: black_scholes(S, K, T, r, sigma, tipo, q) - preco_opcao
    try:
        return brentq(objetivo, 1e-6, 3.0)
    except ValueError:
        return None

def calcular_hv_por_prazo(dias_corridos):
    # converte dias corridos para dias úteis e calcula HV via Yang-Zhang nessa janela
    dias_uteis = max(5, round(dias_corridos * DIAS_ANO / 365))
    return hv_yang_zhang(dias_uteis).iloc[-1]

def classificar(row):
    if row["iv"] is None or pd.isna(row["hv"]):
        return "erro"
    if row["tipo"] == "put" and row["moneyness"] < -0.105:
        ajuste = 1.15
    elif row["tipo"] == "call" and row["moneyness"] > 0.105:
        ajuste = 1.15
    else:
        ajuste = 1.10
    if row["iv"] > row["hv"] * ajuste:
        return "IV mais alta que HV"
    elif row["iv"] < row["hv"] / ajuste:
        return "IV mais baixa que HV"
    else:
        return "IV próxima a HV"

