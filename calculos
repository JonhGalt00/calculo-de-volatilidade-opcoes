            print(f"  Slope:  {skew_slope_calls:.4f}  (negativo = put skew, positivo = call skew)")
            print(f"  Tipo:   {tipo_skew_calls}")
        else:
            print("\n  CALLS — menos de 2 strikes, skew não calculado.")

        print(f"\n--- Interpretação do skew para operações ---")
        for tipo_skew in set(filter(None, [tipo_skew_puts, tipo_skew_calls])):
            if tipo_skew == "negativo (put skew)":
                print("Puts OTM estão mais caras que calls OTM.")
                print("→ Mercado pagando prêmio por proteção de queda.")
                print("→ Venda de puts OTM pode ser atrativa (prêmio elevado).")
                print("→ Spreads de baixa (bear spread) tendem a ser mais caros.")
                print("→ Estruturas como risk reversal favorecem venda de put + compra de call.")
            elif tipo_skew == "positivo (call skew)":
                print("Calls OTM estão mais caras que puts OTM.")
                print("→ Mercado precificando mais risco de alta do que de queda.")
                print("→ Pode indicar expectativa de movimento brusco para cima (evento, resultado).")
                print("→ Venda de calls OTM pode ser atrativa.")
                print("→ Risk reversal invertido: venda de call + compra de put.")
            elif tipo_skew == "smile (ATM mais barato que as pontas)":
                print("IV mais alta nas pontas (OTM) e mais baixa no ATM.")
                print("→ Mercado precificando risco de movimento forte em qualquer direção.")
                print("→ Estratégias de compra de volatilidade (straddle, strangle) podem ser interessantes.")
                print("→ Venda de borboleta (butterfly) pode capturar o prêmio das pontas.")
            elif tipo_skew == "flat":
                print("IV aproximadamente igual em todos os strikes.")
                print("→ Mercado sem viés direcional claro.")
                print("→ Sem vantagem estrutural clara por skew — avaliar HV vs IV.")
            elif tipo_skew == "leve":
                print("Skew leve — inclinação existe mas não é pronunciada.")
                print("→ Tendência de put skew fraco: proteção levemente mais cara.")
                print("→ Sem sinal operacional forte apenas pelo skew.")
    else:
        print("\n⚠️  Skew requer ao menos 2 opções com strikes diferentes na cadeia.")

    # ── Spreads verticais entre strikes adjacentes ────────────────────────────

    if len(CADEIA) >= 2:
        print(f"\n--- Spreads verticais (strikes adjacentes) ---\n")

        for i in range(len(CADEIA) - 1):
            s1 = CADEIA.iloc[i]
            s2 = CADEIA.iloc[i + 1]

            if s1["tipo"] != s2["tipo"]:
                continue

            if s1["tipo"] == "put":
                vendido  = max(s1, s2, key=lambda x: x["strike"])
                comprado = min(s1, s2, key=lambda x: x["strike"])
                nome_spread = "bull put spread"
            elif s1["tipo"] == "call":
                vendido  = min(s1, s2, key=lambda x: x["strike"])
                comprado = max(s1, s2, key=lambda x: x["strike"])
                nome_spread = "bear call spread"

            credito = vendido["preco"] - comprado["preco"]
            largura = abs(vendido["strike"] - comprado["strike"])
            risco   = largura - credito
            ratio   = credito / risco if risco > 0 else None

            if ratio is None:
                interpretacao = "risco inválido — verifique os preços"
            elif ratio >= 0.40:
                interpretacao = "bom → crédito alto em relação ao risco"
            elif ratio >= 0.25:
                interpretacao = "neutro → relação razoável"
            else:
                interpretacao = "ruim → crédito baixo para o risco assumido"

            print(f"  {nome_spread}: vende R$ {vendido['strike']:.2f} / compra R$ {comprado['strike']:.2f}")
            print(f"  Crédito:       R$ {credito:.2f}")
            print(f"  Risco máximo:  R$ {risco:.2f}")
            print(f"  Ratio c/r:     {f'{ratio:.3f}' if ratio is not None else 'N/A'}  → {interpretacao}")
            print()
