            print("\n  PUTS — menos de 2 strikes, skew não calculado.")

        if skew_slope_calls is not None:
            print(f"\n  CALLS")
            print(f"  IV strike mais baixo (R$ {calls['strike'].iloc[0]:.2f}):  {calls['iv'].iloc[0] * 100:.2f}%")
